{
  "name": "zexio-zms-root",
  "version": "1.0.0-preview",
  "private": true,
  "author": "Zexio.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/zexio-io/zexio-zms.git"
  },
  "license": "BSL-1.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev:api": "PORT=3030 pnpm --filter @zexio/zms-api dev",
    "dev:dashboard": "pnpm --filter @zexio/zms-dashboard dev",
    "dev": "pnpm run /^dev:/",
    "test:coverage": "pnpm -r test:coverage",
    "zms": "tsx packages/cli/src/index.ts",
    "zms:init": "pnpm zms init",
    "zms:reset": "pnpm zms reset",
    "zms:start": "pnpm zms start",
    "zms:stop": "pnpm zms stop",
    "cli": "pnpm --filter @zexio/zms-cli",
    "changeset": "changeset",
    "changeset:auto": "node scripts/auto-changeset.mjs",
    "version-packages": "changeset version",
    "release": "changeset publish --access public --provenance"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1"
}
